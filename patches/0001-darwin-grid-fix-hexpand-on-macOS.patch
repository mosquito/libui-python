+		// Also set hugging on the gridChild wrapper so Auto Layout
+		// can directly see the priority at the grid constraint level.
+		[gc setContentHuggingPriority:priority forOrientation:NSLayoutConstraintOrientationHorizontal];
 		// same for vertical direction
 		if (vexpand[gc.top - ymin] || gc.yspan != 1)
