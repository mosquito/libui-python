 }
 
+- (NSSize)intrinsicContentSize
+{
+	// Forward the child control's intrinsic content size so that
+	// content hugging on this wrapper view is meaningful to Auto Layout.
+	return [[self view] intrinsicContentSize];
+}
+
 @end
 
 @implementation gridView
@@ -511,12 +518,16 @@ - (void)establishOurConstraints
 		else
